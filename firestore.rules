rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    // כל משתמש מחובר יכול לקרוא/לעדכן את מסמך עצמו; אדמין יכול לקרוא את כולם
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // כל משתמש מחובר יכול לכתוב רישום פעילות על עצמו בלבד; רק אדמין יכול לקרוא את כל היומן
    match /activity_logs/{logId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isAdmin();
    }

    // רשימת מי שמוגדר אדמין — ניתן לקריאה לכל מחובר (כדי לדעת אם הוא עצמו אדמין), כתיבה רק דרך מסוף Firebase
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
