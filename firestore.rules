rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    // super_admin: נרשם ב-admins collection בעת קידום
    function isSuperAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    // supervisor: role שמור ב-users document
    function isSupervisor() {
      return isSignedIn() && (
        isSuperAdmin() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'supervisor'
      );
    }

    // כל משתמש מחובר יכול לקרוא/לעדכן את מסמך עצמו; super_admin יכול לנהל את כולם
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read, update, delete: if isSuperAdmin();
    }

    // כל משתמש מחובר יכול לכתוב רישום פעילות על עצמו; supervisor ומעלה יכולים לקרוא את כל היומן
    match /activity_logs/{logId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isSupervisor();
    }

    // רשימת super_admin — קריאה לכל מחובר (לדעת אם הוא עצמו super_admin)
    // כתיבה (קידום/הדחה) רק ל-super_admin קיים
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}
